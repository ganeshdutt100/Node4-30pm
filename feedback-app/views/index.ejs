<%- include('components/navbar.ejs') %>
    <div class="max-w-md mx-auto bg-white p-8 rounded-2xl border border-gray-500 shadow">
        <h2 class="text-xl font-bold">Give your feedback</h2>
        <form action="/submit" method="POST" class="space-y-4">
            <input type="text" name="username" placeholder="Enter your name " required
                class="w-full border p-2 rounded-md">
            <input type="email" name="useremail" placeholder="Enter your email" required
                class="w-full border p-2 rounded-md">

            <textarea name="message" id="" cols="30" rows="10" class="w-full border p-2 rounded"></textarea>
            <button type=" submit"
                class="bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-600 transition">Submit</button>
        </form>
    </div>
    <%- include('components/footer.ejs') %>